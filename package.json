{
  "name": "kevlar-4u",
  "version": "1.3.0",
  "description": "Kevlar-4u: A Local-first, MCP-compliant Multi-Agent armor to stress-test your content before the internet does.",
  "main": "dist/index.js",
  "bin": {
    "kevlar-4u": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "setup": "tsx scripts/setup.ts",
    "kevlar-4u": "tsx scripts/cli.ts",
    "test": "tsx --test src/__tests__/*.test.ts",
    "test:watch": "tsx --test --watch src/__tests__/*.test.ts",
    "prepublishOnly": "if [ -z \"$CI\" ]; then echo '⚠️  请通过 CI 发布：git tag vX.X.X && git push origin vX.X.X'; exit 1; fi"
  },
  "files": [
    "dist/",
    "skills/",
    "config/"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "multi-agent",
    "content-review",
    "ai"
  ],
  "author": "9Churze",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/9Churze/kevlar-4u.git"
  },
  "homepage": "https://github.com/9Churze/kevlar-4u#readme",
  "bugs": {
    "url": "https://github.com/9Churze/kevlar-4u/issues"
  },
  "type": "module",
  "dependencies": {
    "@inquirer/prompts": "^7.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.1",
    "dotenv": "^17.4.2",
    "i18next": "^26.3.0",
    "i18next-fs-backend": "^2.6.6"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  }
}
