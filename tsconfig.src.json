{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/index.ts",
    "src/server.ts",
    "src/dao/**/*.ts",
    "src/execution/**/*.ts",
    "src/i18n/**/*.ts",
    "src/prompts/**/*.ts",
    "src/subscription/**/*.ts",
    "src/tools/**/*.ts",
    "src/utils/**/*.ts"
  ],
  "exclude": ["src/pro/**", "src/__tests__/**"]
}
