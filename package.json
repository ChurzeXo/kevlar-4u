{
  "name": "kevlar-4u",
  "version": "1.1.0",
  "description": "Kevlar-4u: A Local-first, MCP-compliant Multi-Agent armor to stress-test your content before the internet does.",
  "main": "dist/index.js",
  "bin": {
    "kevlar-4u": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "setup": "tsx scripts/setup.ts",
    "kevlar-4u": "tsx scripts/cli.ts",
    "test": "tsx --test src/__tests__/**/*.test.ts",
    "test:watch": "tsx --test --watch src/__tests__/**/*.test.ts"
  },
  "files": [
    "dist/",
    "skills/",
    "config/"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": ["mcp", "multi-agent", "content-review", "ai"],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@inquirer/prompts": "^7.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.1",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  }
}
