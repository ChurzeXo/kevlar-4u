{
  "name": "kevlar-4u",
  "version": "1.6.16",
  "description": "Local-first MCP content review server — simulates reader reactions before publishing. 100% offline, no telemetry, AGPL-3.0 open source.",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./execution/strategy": {
      "types": "./dist/execution/strategy.d.ts",
      "import": "./dist/execution/strategy.js"
    },
    "./execution/config": {
      "types": "./dist/execution/config.d.ts",
      "import": "./dist/execution/config.js"
    },
    "./subscription/tier": {
      "types": "./dist/subscription/tier.d.ts",
      "import": "./dist/subscription/tier.js"
    },
    "./subscription/promptTypes": {
      "types": "./dist/subscription/promptTypes.d.ts",
      "import": "./dist/subscription/promptTypes.js"
    },
    "./subscription/promptTemplates": {
      "types": "./dist/subscription/promptTemplates.d.ts",
      "import": "./dist/subscription/promptTemplates.js"
    },
    "./utils/logger": {
      "types": "./dist/utils/logger.d.ts",
      "import": "./dist/utils/logger.js"
    },
    "./utils/observability": {
      "types": "./dist/utils/observability.d.ts",
      "import": "./dist/utils/observability.js"
    }
  },
  "types": "dist/index.d.ts",
  "bin": {
    "kevlar-4u": "dist/scripts/cli.js"
  },
  "scripts": {
    "build": "tsc -b && cp -r src/i18n/locales dist/i18n/locales && chmod +x dist/scripts/cli.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "setup": "tsx scripts/setup.ts",
    "kevlar-4u": "tsx scripts/cli.ts",
    "auto-install": "tsx scripts/cli.ts --auto",
    "build:scripts": "tsc -b tsconfig.scripts.json && chmod +x dist/scripts/cli.js",
    "test": "tsx --test src/__tests__/*.test.ts",
    "test:watch": "tsx --test --watch src/__tests__/*.test.ts",
    "commit:pro": "node ./scripts/sync-pro-submodule.js",
    "sync:backend": "node ./scripts/sync-backend-version.js",
    "deploy:all": "node ./scripts/deploy-all.js",
    "prepublishOnly": "if [ -z \"$CI\" ]; then echo '⚠️  请通过 CI 发布：git tag vX.X.X && git push origin vX.X.X'; exit 1; fi"
  },
  "files": [
    "dist/",
    "config/",
    "scripts/",
    "skills/auditors.json",
    "skills/templates/",
    "skills/fallback.json",
    "skills/xiaohongshu.json",
    "skills/zhihu.json",
    "skills/wechat_official.json",
    "skills/_template.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "multi-agent",
    "content-review",
    "ai"
  ],
  "author": "ChurzeXo",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChurzeXo/kevlar-4u.git"
  },
  "homepage": "https://github.com/ChurzeXo/kevlar-4u#readme",
  "bugs": {
    "url": "https://github.com/ChurzeXo/kevlar-4u/issues"
  },
  "type": "module",
  "dependencies": {
    "@inquirer/prompts": "^7.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.1",
    "dotenv": "^17.4.2",
    "i18next": "^26.3.0",
    "i18next-fs-backend": "^2.6.6",
    "json5": "^2.2.3",
    "ora": "^9.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  }
}
